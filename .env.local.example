# Copie este arquivo para .env.local e configure suas variáveis

# Seu username do GitHub (obrigatório)
GITHUB_USERNAME=seu-usuario-aqui

# Token do GitHub (opcional, mas recomendado para evitar rate limiting)
# Gere em: https://github.com/settings/tokens
GITHUB_TOKEN=your_github_token_here

# Repositórios para ignorar (separados por vírgula)
IGNORED_REPOS=repo_name

# Resend API Key para envio de emails do formulário de contato
RESEND_API_KEY=sua_chave_do_resend

# URL Base do projeto (usado em geradores de rotas/seo)
NEXT_PUBLIC_BASE_URL=http://localhost:3000